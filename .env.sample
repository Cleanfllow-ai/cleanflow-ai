# -----------------------------------------------------------------------
# RightRev Frontend — environment variable template
# Copy this file to .env.local and fill in the values.
# -----------------------------------------------------------------------

# ── AWS / Cognito (NEXT_PUBLIC_ → baked in at build time) ───────────────
NEXT_PUBLIC_AWS_REGION=
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# ── API Gateway & WebSocket ──────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_URL=

# ── S3 ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_S3_BUCKET_NAME=

# ── App URLs ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FRONTEND_BASE_URL=
NEXT_PUBLIC_APP_ORIGIN=

# ── Feature flags ────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_NEW_QUARANTINE_EDITOR=false

# ── Groq (server-side only — chatbot LLM) ───────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# ── Pinecone (server-side only — chatbot RAG) ───────────────────────────
# Get from: https://app.pinecone.io → API Keys
PINECONE_API_KEY=
PINECONE_INDEX_NAME=rightrev-docs
