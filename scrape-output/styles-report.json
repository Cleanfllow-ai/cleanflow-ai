  "keyframes": [
    {
      "selector": ".osano-cm-info",
      "cssText": ".osano-cm-info { animation: 0.4s ease 0s 1 normal none running delay-overflow; bottom: 0px; box-shadow: rgb(204, 204, 204) 0px 0px 2px 2px; box-sizing: border-box; max-width: 20em; overflow: visible; position: fixed; top: 0px; transition-duration: 0.4s; transition-property: transform; width: 100%; }"
    },
    {
      "selector": ".osano-cm-info--open",
      "cssText": ".osano-cm-info--open { animation: auto ease 0s 1 normal none running none; overflow: hidden auto; transform: translate(0px); }"
    },
    {
      "selector": ".osano-cm-info--do_not_sell",
      "cssText": ".osano-cm-info--do_not_sell { animation: auto ease 0s 1 normal none running none; height: fit-content; left: 50%; position: fixed; right: auto; top: 50%; transform: translate(-50%, -50%); transition: none; }"
    },
    {
      "name": "delay-overflow",
      "cssText": "@keyframes delay-overflow { \n  0% { overflow: hidden auto; }\n}"
    },
    {
      "selector": ".osano-cm-disclosure--loading .osano-cm-disclosure__list::after",
      "cssText": ".osano-cm-disclosure--loading .osano-cm-disclosure__list::after { animation-duration: 1s; animation-iteration-count: infinite; animation-name: osano-load-scale; animation-timing-function: ease-in-out; border-radius: 100%; content: \"\"; display: block; height: 1em; position: relative; top: -0.125em; transform: translateY(-50%); width: 1em; }"
    },
    {
      "name": "osano-load-scale",
      "cssText": "@keyframes osano-load-scale { \n  0% { transform: translateY(-50%) scale(0); }\n  100% { opacity: 0; transform: translateY(-50%) scale(1); }\n}"
    },
